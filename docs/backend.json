
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "The spiritual and personal profile of a member.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["bride", "groom"] },
        "profileCreatedBy": { "type": "string", "enum": ["Self", "Parents", "Sibling", "Relative", "Friend"] },
        "maritalStatus": { "type": "string", "enum": ["Never Married", "Widowed", "Divorced", "Awaiting Divorce"] },
        "motherTongue": { "type": "string" },
        "height": { "type": "string" },
        "physicalStatus": { "type": "string", "enum": ["Normal", "Physically Challenged"] },
        "denomination": { "type": "string" },
        "diocese": { "type": "string" },
        "parish": { "type": "string" },
        "education": { "type": "string" },
        "employedIn": { "type": "string", "enum": ["Private", "Government", "Business", "Defense", "Self Employed", "Not Employed"] },
        "occupation": { "type": "string" },
        "annualIncome": { "type": "string" },
        "location": { "type": "string" },
        "familyValue": { "type": "string", "enum": ["Traditional", "Moderate", "Liberal"] },
        "familyType": { "type": "string", "enum": ["Joint", "Nuclear"] },
        "familyStatus": { "type": "string", "enum": ["Middle Class", "Upper Middle Class", "Rich / Affluent"] },
        "eatingHabits": { "type": "string", "enum": ["Vegetarian", "Non-Vegetarian", "Eggetarian"] },
        "drinkingHabits": { "type": "string", "enum": ["No", "Drinks Socially", "Yes"] },
        "smokingHabits": { "type": "string", "enum": ["No", "Occasionally", "Yes"] },
        "bio": { "type": "string" },
        "faithDetails": { "type": "string" },
        "personalityTraits": { "type": "array", "items": { "type": "string" } },
        "targetAudienceDescription": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent between two users.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "text", "timestamp"]
    },
    "Interest": {
      "title": "Interest",
      "description": "An expression of interest from one user to another.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "status", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Public and private profile data for users."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages between users."
    },
    "/interests/{interestId}": {
      "schema": "Interest",
      "description": "Tracking expressions of interest between members."
    }
  }
}
